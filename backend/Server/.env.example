# ---- Server ----
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ---- Database (required for accounts, history, memory, admin) ----
# Free cluster: https://www.mongodb.com/cloud/atlas
# Paste YOUR OWN connection string here (do NOT commit real passwords):
MONGO_URI=

# ---- Auth ----
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Anyone who registers/logs in with an email in this list becomes an admin.
ADMIN_EMAILS=you@example.com

# ---- AI provider: "groq" | "gemini" | "openai" | "mock" ----
# "mock" runs everything with NO key. For a $0 budget, "groq" is recommended.
AI_PROVIDER=mock

# Groq (FREE): https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Google Gemini (free tier): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenAI (paid): https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- GitHub Repo Explainer (OPTIONAL) ----
GITHUB_TOKEN=
